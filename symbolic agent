def learned_decide(observation):
    """
    observation format expected:
      {
        'available_blocks': [
            {'color': 'red', 'pick_pos': [...], 'id': ...},
            {'color': 'white', ...},
            {'color': 'blue', ...}
        ],
        'stack_height': int
      }
    """
    # default placeholders
    color_to_block = {"red": None, "white": None, "blue": None}
    for block in observation["available_blocks"]:
        color_to_block[block["color"]] = block

    def encode_block(block):
        if block is None:
            return [0.0, 0.0, 0.0, 0.0]
        return [
            float(block["pick_pos"][0]),
            float(block["pick_pos"][1]),
            float(block["pick_pos"][2]),
            1.0
        ]

    obs_vec = np.array(
        encode_block(color_to_block["red"]) +
        encode_block(color_to_block["white"]) +
        encode_block(color_to_block["blue"]) +
        [float(observation["stack_height"])],
        dtype=np.float32
    )

    pred_idx, pred_color, pred_probs = predict_next_cube(obs_vec)
    chosen_block = color_to_block[pred_color]

    # fallback in case model picks unavailable color
    if chosen_block is None:
        for color_name in ["red", "white", "blue"]:
            if color_to_block[color_name] is not None:
                chosen_block = color_to_block[color_name]
                pred_color = color_name
                break

    if chosen_block is None:
        return {"action": "wait"}

    target_z = 0.05 + 0.06 * observation["stack_height"]

    return {
        "action": "pick_and_place",
        "block_id": chosen_block["id"],
        "pick_pos": chosen_block["pick_pos"],
        "color": pred_color,
        "place_pos": [0.0, 1.18, target_z],  # replace per robot/platform as needed
        "probs": pred_probs,
    }

